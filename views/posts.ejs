<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>פיד הפוסטים שלי</title>
</head>
<body>
    <h1>פוסטים חדשים</h1>

    <% posts.forEach(post => { %>
        <div style="border: 1px solid #ccc; margin: 10px; padding: 10px;">
            <h2><%= post.title %></h2>
            <p><%= post.content %></p>
            <small>כותב: <%= post.author %> | פורסם בתאריך: <%= post.createdAt.toDateString() %></small>
            
            <form action="/posts/delete/<%= post._id %>" method="POST">
                <button type="submit">מחק פוסט</button>
            </form>
        </div>
    <% }) %>

    <form action="/posts" method="POST">
    <input type="text" name="title" placeholder="כותרת" required>
    <input type="text" name="content" placeholder="תוכן" required>
    <input type="text" name="author" placeholder="כותב" required>
    <button type="submit">שלח פוסט</button>
</form>
<hr>
</body>
</html>